{
  "name": "kingshelp-api",
  "version": "1.0.0",
  "description": "KingsHelp (Incept) - community service-barter backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "node src/db/migrate.js",
    "migrate:pg": "node src/db/migrate.pg.js",
    "seed": "node src/db/seed.js",
    "seed:pg": "node src/db/seed.pg.js",
    "setup": "npm run migrate && npm run seed",
    "prune": "npm prune --omit=dev",
    "test": "node src/tests/smoke.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.6",
