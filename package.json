    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^14.25.0",
    "@sendgrid/mail": "^8.1.5",
    "pg": "^8.14.1",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "pngjs": "^7.0.0"
  },
  "engines": {
    "node": "18.x"
  }
