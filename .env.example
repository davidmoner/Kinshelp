PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Storage (local)
DATA_DIR=.
DB_PATH=./kingshelp.db

# (Optional) When you move to R2/S3 later:
# STORAGE_PROVIDER=r2
# R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# R2_BUCKET=kingshelp
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_PUBLIC_BASE_URL=https://<your-public-cdn-or-domain>
