{
  "permissions": {
    "allow": [
      "Bash(grep:*)",
      "Bash(wc:*)",
      "Bash(test:*)",
      "Bash(node --check *)",
      "Bash(node src/server.js)",
      "Bash(npm run start)",
      "Bash(npm run dev)",
      "Bash(npm run migrate)",
      "Bash(npm run test)",
      "Bash(git status)",
